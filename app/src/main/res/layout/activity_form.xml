<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="40dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="30dp"
                app:cardCornerRadius="40dp"
                app:cardElevation="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="30dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:fontFamily="@font/panaschill_font"
                        android:text="@string/title_form"
                        android:textColor="#263D64"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <!-- Nama -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:fontFamily="@font/panaschill_font"
                        android:text="@string/label_nama"
                        android:textColor="#263D64"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilNama"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:boxBackgroundMode="none">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNama"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/background_input"
                            android:fontFamily="@font/panaschill_font"
                            android:gravity="center_vertical"
                            android:includeFontPadding="false"
                            android:inputType="textPersonName"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:paddingTop="0dp"
                            android:paddingBottom="0dp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Email -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/panaschill_font"
                        android:text="@string/label_email"
                        android:textColor="#263D64"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:boxBackgroundMode="none">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/background_input"
                            android:fontFamily="@font/panaschill_font"
                            android:gravity="center_vertical"
                            android:includeFontPadding="false"
                            android:inputType="textEmailAddress"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:paddingTop="0dp"
                            android:paddingBottom="0dp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- HP -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/panaschill_font"
                        android:text="@string/label_hp"
                        android:textColor="#263D64"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilHp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:hintEnabled="false"
                        app:errorEnabled="true"
                        app:boxBackgroundMode="none">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etHp"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/background_input"
                            android:fontFamily="@font/panaschill_font"
                            android:gravity="center_vertical"
                            android:includeFontPadding="false"
                            android:inputType="phone"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:paddingTop="0dp"
                            android:paddingBottom="0dp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Gender -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/panaschill_font"
                        android:text="@string/label_gender"
                        android:textColor="#263D64"
                        android:textStyle="bold" />

                    <RadioGroup
                        android:id="@+id/rgGender"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbLaki"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/gender_laki"
                            android:fontFamily="@font/panaschill_font"
                            android:textColor="#263D64"
                            android:buttonTint="#263D64"/>

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbPerempuan"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/gender_perempuan"
                            android:fontFamily="@font/panaschill_font"
                            android:textColor="#263D64"
                            android:buttonTint="#263D64"/>
                    </RadioGroup>

                    <!-- Seminar -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/panaschill_font"
                        android:text="@string/label_seminar"
                        android:textColor="#263D64"
                        android:textStyle="bold" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="8dp"
                        app:cardBackgroundColor="#F1F3F9"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp">

                        <Spinner
                            android:id="@+id/spinnerSeminar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:paddingHorizontal="12dp" />
                    </androidx.cardview.widget.CardView>

                    <!-- Checkbox -->
                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cbPersetujuan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="@string/label_persetujuan"
                        android:textColor="#263D64"
                        android:fontFamily="@font/panaschill_font"
                        android:textSize="12sp"
                        app:buttonTint="#263D64"/>

                    <!-- Button Submit -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSubmit"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="24dp"
                        android:backgroundTint="#263D64"
                        android:fontFamily="@font/panaschill_font"
                        android:text="@string/btn_submit"
                        android:textAllCaps="false"
                        android:textColor="#FEDDE9"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:cornerRadius="30dp"
                        app:icon="@drawable/ic_send"
                        app:iconGravity="textStart"
                        app:iconTint="#FEDDE9" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
